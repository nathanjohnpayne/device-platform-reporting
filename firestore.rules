rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAllowedUser() {
      return request.auth != null
        && (
          request.auth.token.email.matches('.*@disney\\.com$')
          || request.auth.token.email.matches('.*@disneystreaming\\.com$')
        );
    }

    function requestOwnsDocument() {
      return isAllowedUser()
        && request.resource.data.createdByUid == request.auth.uid;
    }

    function resourceOwnedByCaller() {
      return isAllowedUser()
        && resource.data.createdByUid == request.auth.uid;
    }

    function importBatchOwnedByCaller(batchId) {
      return exists(/databases/$(database)/documents/importBatches/$(batchId))
        && get(/databases/$(database)/documents/importBatches/$(batchId)).data.createdByUid == request.auth.uid;
    }

    function importBatchWithinRollbackWindow(batchId) {
      return exists(/databases/$(database)/documents/importBatches/$(batchId))
        && withinRollbackWindow(get(/databases/$(database)/documents/importBatches/$(batchId)).data.uploadedAt);
    }

    function createUsesServerTimestamp(fieldName) {
      return request.resource.data[fieldName] == request.time;
    }

    function withinRollbackWindow(fieldName) {
      return fieldName is timestamp
        && request.time < fieldName + duration.value(30, 'd');
    }

    match /adkVersions/{document} {
      allow read, write: if isAllowedUser();
    }

    // This collection is intentionally last-writer-wins because each mapping
    // import replaces the full active partner mapping set.
    match /partnerRegionMappings/{document} {
      allow read, write: if isAllowedUser();
    }

    match /partnerRegionMappingMeta/{document} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser() && document == 'current';
    }

    match /weeklySnapshots/{document} {
      allow read: if isAllowedUser();
      allow create: if requestOwnsDocument() && createUsesServerTimestamp(request.resource.data.uploadedAt);
      allow delete: if resourceOwnedByCaller() && withinRollbackWindow(resource.data.uploadedAt);
    }

    match /adkVersionShare/{document} {
      allow read: if isAllowedUser();
      allow create: if requestOwnsDocument() && createUsesServerTimestamp(request.resource.data.uploadedAt);
      allow delete: if resourceOwnedByCaller() && withinRollbackWindow(resource.data.uploadedAt);
    }

    match /partnerMigration/{document} {
      allow read: if isAllowedUser();
      allow create: if requestOwnsDocument() && createUsesServerTimestamp(request.resource.data.uploadedAt);
      allow delete: if resourceOwnedByCaller() && withinRollbackWindow(resource.data.uploadedAt);
    }

    match /monthlySnapshots/{document} {
      allow read: if isAllowedUser();
      allow create: if requestOwnsDocument() && createUsesServerTimestamp(request.resource.data.uploadedAt);
      allow delete: if resourceOwnedByCaller() && withinRollbackWindow(resource.data.uploadedAt);
    }

    match /importBatches/{document} {
      allow read: if isAllowedUser();
      allow create: if requestOwnsDocument() && createUsesServerTimestamp(request.resource.data.uploadedAt);
      allow delete: if resourceOwnedByCaller() && withinRollbackWindow(resource.data.uploadedAt);
    }

    match /importBatchRollbacks/{document} {
      allow read: if isAllowedUser();
      allow create: if requestOwnsDocument()
        && createUsesServerTimestamp(request.resource.data.rolledBackAt)
        && importBatchOwnedByCaller(document)
        && importBatchWithinRollbackWindow(document);
    }

    match /legacyWorkbookImportBatches/{document} {
      allow read: if isAllowedUser();
      allow create: if requestOwnsDocument() && createUsesServerTimestamp(request.resource.data.importedAt);
    }

    match /legacyWorkbookSheets/{document} {
      allow read: if isAllowedUser();
      allow create: if requestOwnsDocument() && createUsesServerTimestamp(request.resource.data.importedAt);
    }

    match /legacyWorkbookImports/{document} {
      allow read: if isAllowedUser();
      allow create: if requestOwnsDocument() && createUsesServerTimestamp(request.resource.data.importedAt);
      allow update: if resourceOwnedByCaller() && withinRollbackWindow(resource.data.importedAt);
      allow delete: if resourceOwnedByCaller() && withinRollbackWindow(resource.data.importedAt);
    }
  }
}

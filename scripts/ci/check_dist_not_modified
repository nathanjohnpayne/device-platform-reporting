#!/usr/bin/env bash
# check_dist_not_modified — Verifies dist/ files were not directly modified (only additions allowed).
# Uses --diff-filter=M to check modifications only; adding .gitkeep files does not trigger this check.
# Exit 0 = pass, Exit 1 = fail.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

# Check if we have at least two commits to compare
if ! git -C "$REPO_ROOT" rev-parse HEAD~1 >/dev/null 2>&1; then
  echo "check_dist_not_modified: SKIP (not enough commits to compare)"
  exit 0
fi

MODIFIED=$(git -C "$REPO_ROOT" diff --name-only --diff-filter=M HEAD~1 HEAD -- dist/ 2>/dev/null)

if [[ -n "$MODIFIED" ]]; then
  echo "FAIL: dist/ files were directly modified (run 'npm run build' instead):"
  echo "$MODIFIED"
  echo "check_dist_not_modified: FAIL"
  exit 1
fi

echo "check_dist_not_modified: PASS"
exit 0

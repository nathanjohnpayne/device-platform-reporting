#!/usr/bin/env bash
# check_spec_test_alignment — Advisory check: verifies specs/ files have corresponding test coverage.
# ADVISORY MODE: This repo's specs/ directory contains product briefs and feature documentation,
# not per-feature test spec files. The Jest suite covers app behavior but does not follow a
# one-spec-one-test file naming convention. Mismatches produce warnings only (exit 0).
# Exit 0 = pass (including advisory warnings), Exit 1 = hard failure only.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
SPECS_DIR="$REPO_ROOT/specs"
TESTS_DIR="$REPO_ROOT/tests"

if [[ ! -d "$SPECS_DIR" ]]; then
  echo "check_spec_test_alignment: SKIP (no specs/ directory)"
  exit 0
fi

SPEC_FILES=()
while IFS= read -r -d '' f; do
  SPEC_FILES+=("$f")
done < <(find "$SPECS_DIR" -name "*.md" -print0 2>/dev/null)

if [[ ${#SPEC_FILES[@]} -eq 0 ]]; then
  echo "check_spec_test_alignment: PASS (no spec files found)"
  exit 0
fi

UNMATCHED=0
for spec in "${SPEC_FILES[@]}"; do
  spec_name="$(basename "$spec" .md)"
  # Look for a corresponding test file anywhere in the repo src/ or tests/
  if ! find "$REPO_ROOT/src" "$TESTS_DIR" -name "*${spec_name}*" -name "*.test.*" 2>/dev/null | grep -q .; then
    echo "ADVISORY: No test file found for spec: $(basename "$spec")"
    UNMATCHED=1
  fi
done

if [[ $UNMATCHED -eq 1 ]]; then
  echo "check_spec_test_alignment: ADVISORY — specs/ contains product briefs/docs rather than per-test spec files."
  echo "  The Jest suite covers app behavior. No action required."
  exit 0
fi

echo "check_spec_test_alignment: PASS"
exit 0
